{
  "version": 2,
  "functions": {
    "api/cookies.py": { "maxDuration": 15 },
    "api/download.py": { "maxDuration": 60 },
    "api/info.py": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/public/index.html" }
  ]
}
